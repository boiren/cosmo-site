# ─── Sunucu ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB ──────────────────────────────────────────────────
# Atlas (production): mongodb+srv://user:pass@cluster.mongodb.net/cosmo
# Lokal (dev):        mongodb://localhost:27017/cosmo
MONGODB_URI=

# ─── JWT ──────────────────────────────────────────────────────
# openssl rand -base64 48   →  güvenli random string üretir
JWT_SECRET=
JWT_EXPIRES_IN=30d
JWT_EXPIRE=30d

# ─── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=https://mihomesanal.com

# ─── Admin seed (ilk kurulumda kullanılır) ────────────────────
ADMIN_EMAIL=admin@mihomesanal.com
ADMIN_PASSWORD=

# ─── E-posta (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Cosmo Technology <noreply@mihomesanal.com>
MAIL_FROM=Cosmo Technology <noreply@mihomesanal.com>

# ─── Ödeme ────────────────────────────────────────────────────
PAYMENT_PROVIDER=placeholder
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox.iyzipay.com
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
