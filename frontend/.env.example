# ─── API URL ─────────────────────────────────────────────────
# Geliştirme: BOŞALT — Vite proxy /api → localhost:5000 yönlendirir
# Production: Backend URL'ini yaz (trailing slash olmadan)
VITE_API_URL=https://api.mihomesanal.com

# ─── Geliştirme notu ──────────────────────────────────────────
# .env.local dosyası da kullanılabilir (git'e eklenmez):
